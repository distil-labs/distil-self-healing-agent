# Root-level local development variables.
#
# Copy to .env if you use Python helper scripts or direct Distil debugging:
#   cp .env.example .env

DISTIL_ENDPOINT=https://your-inference-endpoint/v1/completions
DISTIL_API_KEY=your_distil_api_key
DISTIL_MODEL=distillabs/massive-iot-traces1

# Local Worker URL used by Python helpers and Oz launcher.
WORKER_URL=http://localhost:8788

# Optional for headless/cloud Oz runs.
WARP_API_KEY=wk-your-warp-api-key
OZ_ENVIRONMENT_ID=
OZ_AUTO_TRIGGER=false
